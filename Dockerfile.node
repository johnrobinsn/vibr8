FROM python:3.12-slim

# System dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl build-essential ca-certificates gnupg && \
    rm -rf /var/lib/apt/lists/*

# Node.js 20 LTS (required for Claude Code CLI)
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - && \
    apt-get install -y --no-install-recommends nodejs && \
    rm -rf /var/lib/apt/lists/*

# Claude Code CLI
RUN npm install -g @anthropic-ai/claude-code

# uv (Python package manager)
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# Python dependencies — only what vibr8-node needs (skip torch/audio/ML)
WORKDIR /app
RUN uv venv /app/.venv && \
    VIRTUAL_ENV=/app/.venv uv pip install \
    "aiohttp>=3.9" \
    "bcrypt>=4.0" \
    "mcp>=1.0" \
    "httpx>=0.27" \
    "json5>=0.9" \
    "python-dotenv>=1.0" \
    "huggingface-hub>=0.20" \
    "numpy>=1.26"

# Create non-root user (Claude Code refuses bypassPermissions as root)
RUN useradd -m -s /bin/bash vibr8 && \
    chown -R vibr8:vibr8 /app
RUN mkdir -p /code && chown vibr8:vibr8 /code

# Copy vibr8 source (server modules + node agent)
COPY --chown=vibr8:vibr8 server/ /app/server/
COPY --chown=vibr8:vibr8 vibr8_node/ /app/vibr8_node/
COPY --chown=vibr8:vibr8 pyproject.toml /app/pyproject.toml
COPY --chown=vibr8:vibr8 bin/docker-entrypoint.sh /app/docker-entrypoint.sh
RUN chmod +x /app/docker-entrypoint.sh

# Runtime environment
ENV PATH="/app/.venv/bin:$PATH"
ENV PYTHONPATH="/app"
ENV WORK_DIR="/code"

USER vibr8
WORKDIR /code
ENTRYPOINT ["/app/docker-entrypoint.sh"]
